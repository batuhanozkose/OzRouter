# OzRouter .gitignore

# ── Bağımlılıklar ──────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────────────────
.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# ── Ortam Değişkenleri ────────────────────────────────────────
.env*
!.env.example

# ── Veritabanı ve Veri ────────────────────────────────────────
data/
.data/
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite-journal

# ── Günlükler ─────────────────────────────────────────────────
logs/*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
app.log

# ── Test ve Kapsam ────────────────────────────────────────────
coverage/
coverage**
.nyc_output/
test-results/
playwright-report/
blob-report/
.vitest/

# ── Derleme Çıktıları ─────────────────────────────────────────
/app/
/dist/
*.tgz

# ── Electron ─────────────────────────────────────────────────
electron/package-lock.json
electron/dist-electron/
electron/out/
electron/release/
electron/releases/
electron/node_modules/
icon.iconset/

# ── SQLite Artıkları ─────────────────────────────────────────
# (yukarıda data/ altında ele alındı)

# ── IDE ve Editör ────────────────────────────────────────────
.idea/
.DS_Store
*.pem
.config/
.vscode/settings.json
.eslintcache

# ── Araç Önbellekleri ────────────────────────────────────────
.cache/
.turbo/
.vite/

# ── Vercel ───────────────────────────────────────────────────
.vercel

# ── Analiz ve Planlama (üretilmiş, izlenmez) ────────────────
.analysis/
antigravity-manager-analysis/
.sisyphus/
.plans/
.superpowers/

# ── Playwright Artıkları ─────────────────────────────────────
.tmp/

# ── Güvenlik Analizi (kendi git deposu) ─────────────────────
security-analysis/

# ── Yerel Agent Yapılandırmaları ─────────────────────────────
.gemini/
.omx/
.gitnexus
.worktrees
.gh-discussions.json
.commandcode

# ── open-sse Testleri ────────────────────────────────────────
open-sse/test/*

# ── Özel Dizinler ────────────────────────────────────────────
ozrouterCloud/
ozrouterSite/

# ── Kök Düzey Alt Çizgi Ön Ekli Dizinler (özel/taslak) ─────
/_*/

# ── VS Code Uzantısı (bağımsız git reposu) ──────────────────
vscode-extension/

# ── Boş/Takılı Dosyalar ─────────────────────────────────────
typescript
